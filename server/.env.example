# ─── OBLIGATORIAS ─────────────────────────────────────────────────────────────
# Cadena de conexión a PostgreSQL.
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_DB
# Local:   postgresql://postgres:tu_contraseña@localhost:5432/michanga
# Prod:    obtener de Neon / Railway / Supabase (ver DEPLOY.md)
DATABASE_URL="postgresql://postgres:tu_contraseña@localhost:5432/michanga"

# Clave secreta para firmar los JWT. En producción debe ser larga y aleatoria.
# Generá una así: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="cambia_esto_por_un_string_largo_y_aleatorio_de_al_menos_32_caracteres"

# ─── OPCIONALES CON VALOR POR DEFECTO ─────────────────────────────────────────
# Puerto del servidor Express. Default: 4000
PORT=4000

# URL del frontend. Usada para CORS y para las URLs de retorno de MercadoPago.
# Local:  http://localhost:5173  (valor por defecto si no se define)
# Prod:   la URL pública de tu frontend (ej: https://michanga.vercel.app)
CLIENT_URL="http://localhost:5173"

# ─── MERCADOPAGO (dejar vacías para desarrollo sin pagos) ─────────────────────
# Sin estas variables el servidor arranca igual. Auth, postulaciones, mensajes
# y calificaciones funcionan completos. Solo falla si intentás iniciar un pago.
#
# Cómo obtenerlas:
#   1. Ir a https://www.mercadopago.com.ar/developers/panel
#   2. Crear una aplicación
#   3. Credenciales de PRUEBA (Sandbox) → copiar Access Token
#   4. Para producción → reemplazar por las credenciales productivas
MP_ACCESS_TOKEN=""

# URL pública del servidor — MercadoPago la usa para llamar al webhook.
# Local:  necesitás ngrok: ngrok http 4000  →  copiar la URL HTTPS generada
#         Podés dejarlo vacío: el webhook no funciona pero los retornos sí.
# Prod:   la URL real del servidor (ej: https://michanga-api.railway.app)
SERVER_URL=""

# Comisión de la plataforma en % (ej: 5 = 5%). Requiere MP Marketplace en prod.
# Default: 0 (sin comisión). Dejar en 0 para desarrollo.
PLATFORM_FEE_PERCENT=0
