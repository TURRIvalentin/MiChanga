{
  "name": "michanga-server",
  "version": "1.0.0",
  "description": "Backend para MiChanga - marketplace de changas en Argentina",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
    "db:seed": "node prisma/seed.js",
    "db:reset": "prisma migrate reset --force && node prisma/seed.js",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "5.7.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^2.0.0",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.6.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "prisma": "5.7.1"
  }
}
