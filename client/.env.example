# Copy to .env for local frontend settings.
# In Vercel, configure these as Environment Variables for the frontend project.

# Backend origin. Do not include /api at the end.
# Local dev can leave this empty to use the Vite proxy in vite.config.js.
VITE_API_URL=https://michanga-production.up.railway.app

# Change to true when MercadoPago is enabled.
VITE_PAYMENTS_ENABLED=false
